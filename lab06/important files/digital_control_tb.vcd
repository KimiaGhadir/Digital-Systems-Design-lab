$var integer 32 ; ss $end
$var integer 32 < t $end

$scope function exp_thermal_next $end
$var reg 2 = exp_thermal_next [1:0] $end
$var reg 2 > state [1:0] $end
$var reg 8 ? temp [7:0] $end
$upscope $end

$scope function exp_speed_next $end
$var reg 2 @ exp_speed_next [1:0] $end
$var reg 2 A th_state [1:0] $end
$var reg 2 B sp_state [1:0] $end
$var reg 8 C temp [7:0] $end
$var reg 2 D th_next [1:0] $end
$upscope $end

$scope function exp_heater $end
