$var reg 2 W e_sp [1:0] $end
$upscope $end

$scope task run_reset_test $end
$upscope $end

$scope task run_directed_thermal_sequence $end
$upscope $end

$scope task run_directed_speed_sequence $end
$upscope $end

$scope task run_boundary_tests $end
$upscope $end

$scope task run_exhaustive_transition_tests $end
$upscope $end

$scope task run_illegal_state_recovery_test $end
$upscope $end

