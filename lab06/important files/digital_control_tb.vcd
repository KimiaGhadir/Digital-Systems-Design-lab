$var parameter 2 ) CRS_6 $end
$var parameter 2 * CRS_8 $end
$var reg 1 + clk $end
$var reg 1 , rst_n $end
$var reg 8 - temp_c [7:0] $end
$var wire 1 . heater_on $end
$var wire 1 / cooler_on $end
