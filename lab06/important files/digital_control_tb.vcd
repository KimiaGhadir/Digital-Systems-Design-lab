$var reg 2 K sp_state [1:0] $end
$upscope $end

$scope task apply_reset $end
$upscope $end

$scope task step_temp_and_check $end
$var reg 8 L new_temp [7:0] $end
$var reg 2 M exp_th [1:0] $end
$var reg 2 N exp_sp [1:0] $end
